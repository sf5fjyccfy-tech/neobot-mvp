# =============================================================================
# NeoBot — Variables d'environnement (Hetzner VPS)
# =============================================================================
# USAGE :
#   cp .env.example .env
#   nano .env          ← remplir TOUTES les valeurs marquées CHANGE_THIS
#
# Ce fichier EST dans git. Le .env NE DOIT PAS l'être (il est dans .gitignore).
# =============================================================================


# =============================================================================
# DATABASE — Neon.tech (PostgreSQL externe)
# =============================================================================
# Coller l'URL de connexion depuis le dashboard Neon → Settings → Connection string
# Format : postgresql://user:password@host.neon.tech/neobot_db?sslmode=require
DATABASE_URL=CHANGE_THIS_NEON_URL

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30


# =============================================================================
# SÉCURITÉ
# =============================================================================
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_64_CHAR_HEX

# CORS — URLs autorisées à appeler le backend (séparées par virgule, sans espace)
# Ex : https://neobot-ai.com,https://www.neobot-ai.com
ALLOWED_ORIGINS=CHANGE_THIS_FRONTEND_URL

# Clé partagée entre le backend et le service WhatsApp (réseau interne)
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=CHANGE_THIS_64_CHAR_HEX


# =============================================================================
# WHATSAPP SERVICE
# =============================================================================
# Ne pas changer ces deux lignes — adressage interne Docker
WHATSAPP_BACKEND_URL=http://backend:8000
WHATSAPP_SERVICE_URL=http://whatsapp:3001
WHATSAPP_PORT=3001

# Secret HMAC pour valider les webhooks entrants de Baileys
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
WHATSAPP_WEBHOOK_SECRET=CHANGE_THIS_64_CHAR_HEX


# =============================================================================
# DEEPSEEK (LLM)
# =============================================================================
DEEPSEEK_API_KEY=CHANGE_THIS
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30


# =============================================================================
# KORAPAY (Paiements — NeoCaisse)
# =============================================================================
# Clé secrète depuis le dashboard Korapay → API Keys
KORAPAY_SECRET_KEY=CHANGE_THIS


# =============================================================================
# BREVO (Emails transactionnels)
# =============================================================================
# Clé API depuis dashboard Brevo → Settings → API Keys
BREVO_API_KEY=CHANGE_THIS
BREVO_SENDER_EMAIL=contact@neobot-ai.com
BREVO_SENDER_NAME=NeoBot
BREVO_REPLY_TO=contact@neobot-ai.com
FRONTEND_URL=CHANGE_THIS_FRONTEND_URL


# =============================================================================
# SENTRY (Monitoring)
# =============================================================================
# DSN depuis dashboard Sentry → Settings → Projects → DSN
SENTRY_DSN=CHANGE_THIS_SENTRY_DSN


# =============================================================================
# APP
# =============================================================================
APP_ENV=production
APP_NAME=NeoBot
DEBUG_MODE=false
LOG_LEVEL=INFO

# Email du superadmin (OBLIGATOIRE — sans ça, la réinitialisation admin ne marche pas)
SUPERADMIN_EMAIL=CHANGE_THIS_ADMIN_EMAIL
