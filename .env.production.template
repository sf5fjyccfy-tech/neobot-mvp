# ========== DATABASE ==========
# CHANGE THESE BEFORE DEPLOYMENT TO PRODUCTION!
DATABASE_URL=postgresql://neobot:CHANGE_THIS_PASSWORD_32_CHARS@localhost:5432/neobot_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# ========== API KEYS ==========
# CHANGE THESE TO YOUR ACTUAL PRODUCTION KEYS!
DEEPSEEK_API_KEY=CHANGE_THIS_API_KEY
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ========== BACKEND ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=production
BACKEND_DEBUG=false
BACKEND_RELOAD=false

# ========== WHATSAPP SERVICE ==========
WHATSAPP_PORT=3001
WHATSAPP_BACKEND_URL=https://api.yourdomain.com
WHATSAPP_SERVICE_URL=https://whatsapp.yourdomain.com
WHATSAPP_WEBHOOK_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX
WHATSAPP_RECONNECT_TIMEOUT=30
WHATSAPP_MAX_RETRIES=5

# ========== FRONTEND ==========
FRONTEND_PORT=3000
FRONTEND_URL=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WHATSAPP_URL=https://whatsapp.yourdomain.com

# ========== APP CONFIG ==========
APP_NAME=NéoBot
APP_VERSION=1.0.0
APP_ENV=production
DEBUG_MODE=false

# ========== SECURITY ==========
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_VALUE
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FILE=/var/log/neobot/app.log
LOG_FORMAT=json

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# ========== MONITORING & ALERTING ==========
# Configure these for your monitoring service
SENTRY_DSN=
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# ========== AWS/CLOUD SERVICES ==========
# Optional: For S3 backups, photo storage, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=neobot-backups

# ========== PAYMENT PROCESSING ==========
# Only needed in Phase 2 (payment integration)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

