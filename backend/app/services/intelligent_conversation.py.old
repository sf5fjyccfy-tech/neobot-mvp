"""
Module SPIN Selling corrigé - Version robuste sans dépendance DB
"""
def get_conversation_response(message: str, db=None, tenant_id=None, phone=None) -> str:
    """
    Cerveau SPIN Selling ultra-robuste (pas de dépendance DB critique)
    """
    message_lower = message.lower().strip()
    
    # Phrases d'accroche SPIN optimisées pour WhatsApp
    spin_responses = {
        "salutation": "👋 Salut ! Je suis NéoBot, l'assistant IA qui automatise WhatsApp.\n\n"
                     "🚀 Je fais gagner 2-3h/jour aux entreprises en répondant 24/7 aux clients.\n\n"
                     "Tu veux voir une démo gratuite ?",
        
        "presentation": "🤖 **NÉOBOT** - Ton vendeur automatique sur WhatsApp !\n\n"
                       "• Réponds 24h/24 à tes clients\n"
                       "• Gère commandes, réservations, infos\n"
                       "• Analytics en temps réel\n"
                       "• À partir de 20k FCFA/mois\n\n"
                       "Essai gratuit 14 jours. Intéressé ? 😊",
        
        "prix": "💰 **TARIFS NÉOBOT** :\n\n"
               "🏷️ BASIQUE : 20k/mois (2000 messages)\n"
               "🏷️ STANDARD : 50k/mois (messages illimités)\n"
               "🏷️ PRO : 90k/mois (API + support prioritaire)\n\n"
               "🎁 Essai gratuit 14 jours !\n"
               "Tu veux commencer l'essai ?",
        
        "demo": "🎬 **DÉMO IMMÉDIATE** :\n\n"
                "1. Dis-moi ton secteur (restaurant, boutique, etc.)\n"
                "2. Je deviens ton assistant personnalisé\n"
                "3. Tu vois en direct comment je réponds\n"
                "4. On active l'essai gratuit si ça te plaît !\n\n"
                "Alors, c'est quoi ton secteur d'activité ?",
        
        "secteur": "🎯 **PARFAIT !** Pour NéoBot :\n\n"
                  "• Restaurant : Gère menu, horaires, réservations, livraison\n"
                  "• Boutique : Gère catalogue, stocks, prix, livraison\n"
                  "• Service : Gère RDV, tarifs, disponibilités\n\n"
                  "Je m'adapte à 100% à ton business. Quel est ton secteur exact ?",
        
        "default": "🚀 **NÉOBOT** transforme ton WhatsApp en machine à ventes !\n\n"
                  "Je réponds automatiquement, je convertis les clients, je prends les commandes.\n\n"
                  "• Gain de temps : 2-3h/jour\n"
                  "• Plus de ventes : réponse instantanée\n"
                  "• Clients heureux : service 24/7\n\n"
                  "Essai gratuit 14 jours. On commence ?"
    }
    
    # Détection simple et robuste
    if any(word in message_lower for word in ["salut", "bonjour", "hello", "bonsoir", "coucou", "bjr", "slt"]):
        return spin_responses["salutation"]
    
    elif any(word in message_lower for word in ["qui es", "présente", "explique", "c'est quoi", "néobot", "raconte"]):
        return spin_responses["presentation"]
    
    elif any(word in message_lower for word in ["prix", "tarif", "combien", "coûte", "abonnement", "payer"]):
        return spin_responses["prix"]
    
    elif any(word in message_lower for word in ["démo", "montre", "voir", "essayer", "tester", "démonstration"]):
        return spin_responses["demo"]
    
    elif any(word in message_lower for word in ["restaurant", "boutique", "shop", "magasin", "service", "coiffure", "salon"]):
        return spin_responses["secteur"]
    
    elif any(word in message_lower for word in ["oui", "d'accord", "ok", "vas-y", "intéressé", "go", "let's go"]):
        return "✅ **SUPER !** 🎉\n\nPour activer ton essai gratuit :\n\n1. Quel est ton secteur exact ?\n2. Quel est ton nom/prénom ?\n3. On configure NéoBot pour toi en 5 min !\n\nTu es prêt ?"
    
    elif any(word in message_lower for word in ["non", "pas intéressé", "plus tard", "not now", "maybe"]):
        return "😊 Pas de souci ! NéoBot sera là quand tu auras besoin.\n\nEn attendant, tu veux voir une petite démo de ce que je peux faire pour ton business ?"
    
    else:
        # Réponse engageante pour messages non reconnus
        return spin_responses["default"]
