"""
Service de Fallback INTELLIGENT - TOUJOURS privilégier l'IA Closer
"""
import re
from typing import Dict, List, Tuple, Optional
from sqlalchemy.orm import Session


import re
from typing import Tuple
from sqlalchemy.orm import Session
from app.ai_prompts import detect_mode, get_fallback_template

class FallbackService:
    def __init__(self, db: Session):
        self.db = db

    def detect_intent(self, message: str, business_type: str, business_name: str) -> Tuple[str, str]:
        """
        Détecte l'intention et le mode - Version optimisée pour le PACK ULTIME
        """
        message_lower = message.lower().strip()
        mode = detect_mode(business_type, business_name)
        
        # MODE NÉOBOT ADMIN
        if mode == "neobot_admin":
            if any(word in message_lower for word in ["bonjour", "salut", "hello", "coucou"]):
                return "salutation", mode
            elif any(word in message_lower for word in ["quoi", "comment", "fonctionne", "c'est quoi", "explique"]):
                return "what_is", mode
            elif any(word in message_lower for word in ["prix", "combien", "coûte", "tarif", "20k", "50k", "90k"]):
                return "pricing", mode
            elif any(word in message_lower for word in ["exemple", "montre", "démo", "test"]):
                return "demo", mode
            elif any(word in message_lower for word in ["ok", "oui", "go", "commencer", "d'accord"]):
                return "closing", mode
            else:
                return "default", mode
        
        # MODE CLIENT
        else:
            if any(word in message_lower for word in ["bonjour", "salut", "hello"]):
                return "salutation", mode
            elif any(word in message_lower for word in ["prix", "combien", "coûte", "tarif"]):
                return "pricing", mode
            elif any(word in message_lower for word in ["commander", "acheter", "prendre", "réserver"]):
                return "order", mode
            elif any(word in message_lower for word in ["produit", "service", "quoi", "faire"]):
                return "what_do_you_do", mode
            else:
                return "default", mode

    def get_fallback_response(self, message: str, business_type: str, business_name: str) -> str:
        """
        Génère une réponse de fallback avec le PACK ULTIME
        """
        intent, mode = self.detect_intent(message, business_type, business_name)
        
        # Utiliser les templates du PACK ULTIME
        response = get_fallback_template(mode, intent, business_name)
        
        # Post-processing pour correspondre au style demandé
        response = response.strip()
        
        # S'assurer que c'est court (3-4 lignes max)
        lines = response.split('\n')
        if len(lines) > 4:
            response = '\n'.join(lines[:4])
        
        return response

    def should_use_fallback(self, message: str, ai_available: bool = True) -> bool:
        """
        Décision intelligente : quand utiliser le fallback vs l'IA
        """
        message_lower = message.lower().strip()
        
        # Toujours fallback si IA indisponible
        if not ai_available:
            return True
        
        # Messages très simples → fallback (économise l'IA)
        simple_patterns = [
            r"^(bonjour|salut|hello|coucou)[\s!?]*$",
            r"^(merci|thanks|ok|d'accord)[\s!?]*$",
            r"^[^a-z]*$"  # Pas de lettres
        ]
        
        for pattern in simple_patterns:
            if re.match(pattern, message_lower, re.IGNORECASE):
                return True
        
        # Messages très courts → fallback
        if len(message_lower.split()) <= 3:
            return True
            
        return False
