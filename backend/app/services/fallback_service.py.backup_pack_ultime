        """Fallback intelligent pour messages simples"""
        message_lower = message.lower().strip()
        
        if any(word in message_lower for word in ["salut", "bonjour", "hello", "bonsoir"]):
            return f"👋 Bonjour ! Bienvenue chez {business_name} ! 🚀\n\nJe suis NÉOBOT, votre expert en automatisation WhatsApp. Comment puis-je vous aider à booster vos ventes aujourd'hui ?"
        
        elif any(word in message_lower for word in ["merci", "thanks"]):
            return "🙏 Avec plaisir ! Le meilleur reste à venir... \n\nQuelle est VOTRE plus grande frustration avec WhatsApp actuellement ?"
            
        return f"🚀 Bienvenue chez {business_name} ! Je suis NÉOBOT, spécialiste de la conversion WhatsApp. Parlons de vos objectifs ! 💎"

