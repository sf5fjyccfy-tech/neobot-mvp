import re
from typing import Dict, List, Tuple, Optional
from sqlalchemy.orm import Session

class FallbackService:
    def __init__(self, db: Session):
        self.db = db

    def should_use_fallback(self, message: str, ai_available: bool = True) -> bool:
        """
        STRATÉGIE : TOUJOURS utiliser l'IA Closer sauf :
        - IA complètement indisponible
        - Messages ultra-simples (salut/merci)
        """
        message_lower = message.lower().strip()
        
        # Messages ultra-simples → Fallback rapide
        simple_patterns = [
            r"^(salut|bonjour|bonsoir|hello)[\s!?]*$",
            r"^(merci|thanks|ok|d'acc)[\s!?]*$",
        ]
        
        for pattern in simple_patterns:
            if re.match(pattern, message_lower, re.IGNORECASE):
                return True  # Fallback pour messages simples
                
        # TOUJOURS l'IA pour le reste (démos, questions, objections)
        return not ai_available

