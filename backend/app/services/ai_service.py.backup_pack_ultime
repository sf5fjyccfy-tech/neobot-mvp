from app.ai_prompts import detect_mode, get_template

"""
Service IA corrigé pour NéoBot
Gère à la fois les appels avec objet tenant et paramètres séparés
"""
import os
import httpx
from typing import Union

DEEPSEEK_API_KEY = os.getenv("DEEPSEEK_API_KEY", "sk-test")
DEEPSEEK_URL = "https://api.deepseek.com/v1/chat/completions"

async def generate_ai_response(
    message: str, 
    business_info: Union[str, dict],  # Accepte string ou dict
    business_name: str = None,
    conversation_history: list = None
) -> str:
    """
    Génère une réponse IA intelligente
    
    Args:
        message: Message de l'utilisateur
        business_info: Soit un string (business_type), soit un dict/objet avec .business_type
        business_name: Nom de l'entreprise (optionnel si dans business_info)
        conversation_history: Historique de conversation
    """
    
    # 1. Extraire business_type et business_name proprement
    business_type = "service"
    extracted_name = "NéoBot"
    
    if isinstance(business_info, str):
        # business_info est déjà un string (business_type)
        business_type = business_info
        if business_name:
            extracted_name = business_name
    elif hasattr(business_info, 'business_type'):
        # business_info est un objet avec attributs
        business_type = business_info.business_type
        if hasattr(business_info, 'name'):
            extracted_name = business_info.name
    elif isinstance(business_info, dict):
        # business_info est un dict
        business_type = business_info.get('business_type', 'service')
        extracted_name = business_info.get('name', business_name or 'NéoBot')
    
    # Fallback si vide
    if not business_type or business_type == "autre":
        business_type = "service"
    if not extracted_name:
        extracted_name = "NéoBot"
    
    # 2. Réponses simples pour messages basiques (économie de tokens)
    message_lower = message.lower().strip()
    simple_responses = {
        "bonjour": f"👋 Bonjour ! Bienvenue chez {extracted_name}. Je suis NÉOBOT, votre assistant IA. Comment puis-je vous aider aujourd'hui ?",
        "salut": f"👋 Salut ! Ravie de vous rencontrer. Je suis l'IA de {extracted_name}, prête à vous assister.",
        "hello": f"👋 Hello ! Bienvenue chez {extracted_name}. En quoi puis-je vous être utile ?",
        "merci": "🙏 Je vous en prie ! N'hésitez pas si vous avez d'autres questions.",
        "ok": "👍 Parfait ! Dites-moi si vous avez besoin d'autre chose.",
        "ça va": "😊 Très bien, merci ! Et vous, comment allez-vous ?",
    }
    
    for key, response in simple_responses.items():
        if key in message_lower and len(message_lower.split()) <= 3:
            return response
    
    # 3. Prompts professionnels par secteur
    system_prompts = {
        "restaurant": f"""Tu es NÉOBOT, l'assistant IA intelligent de {extracted_name}, un restaurant de qualité.

RÔLE:
- Assistant professionnel et amical
- Connaisseur de la cuisine camerounaise
- Réponses concises (1-2 phrases maximum)

INFORMATIONS:
- Menu: Plats camerounais (Ndolé, Poulet DG, Eru, Poisson braisé)
- Prix: 2000-5000 FCFA
- Horaires: 11h-22h tous les jours
- Livraison: Disponible, 30-45 min

STYLE:
- Professionnel mais chaleureux
- Propose des options
- Pas de forcing commercial
- Réponds précisément à la question

Exemple: "Bonjour ! Nous avons du Ndolé à 2500 FCFA et du Poulet DG à 3500 FCFA. Souhaitez-vous réserver ?" """,
        
        "boutique": f"""Tu es NÉOBOT, l'assistant IA de {extracted_name}, une boutique.

RÔLE:
- Conseiller produits professionnel
- Informe sur disponibilité et prix
- Réponses utiles et concises

INFORMATIONS:
- Produits: Vêtements, accessoires, électronique
- Paiement: Orange Money, MTN Money, cash
- Livraison: 24-48h en ville

STYLE:
- Pro et serviable
- Donne des informations claires
- Propose des alternatives si indisponible""",
        
        "service": f"""Tu es NÉOBOT, l'assistant IA de {extracted_name}.

RÔLE:
- Professionnel et compétent
- Explique les services clairement
- Aide à prendre rendez-vous

STYLE:
- Claire et précise
- Propose des créneaux
- Donne les informations nécessaires""",
        
        "saas": f"""Tu es NÉOBOT, l'assistant IA de {extracted_name}, une plateforme SaaS.

RÔLE:
- Expert en automatisation WhatsApp
- Explique les fonctionnalités
- Aide à démarrer

INFORMATIONS:
- Automatisation des réponses WhatsApp
- IA intelligente + fallback
- Dashboard analytics
- Pour TPE/PME camerounaises

STYLE:
- Technique mais accessible
- Montre la valeur
- Réponds aux objections""",
    }
    
    system_prompt = system_prompts.get(business_type, system_prompts["service"])
    
    # 4. Construction des messages pour l'API
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": message}
    ]
    
    # Ajouter l'historique si disponible
    if conversation_history:
        messages = [{"role": "system", "content": system_prompt}] + conversation_history[-5:] + [{"role": "user", "content": message}]
    
    # 5. Appel à l'API DeepSeek
    try:
        async with httpx.AsyncClient(timeout=15.0) as client:
            response = await client.post(
                DEEPSEEK_URL,
                headers={
                    "Authorization": f"Bearer {DEEPSEEK_API_KEY}",
                    "Content-Type": "application/json"
                },
                json={
                    "model": "deepseek-chat",
                    "messages": messages,
                    "temperature": 0.7,
                    "max_tokens": 150,
                    "stream": False
                }
            )
            
            if response.status_code == 200:
                result = response.json()
                ai_response = result["choices"][0]["message"]["content"]
                
                # Nettoyer la réponse
                ai_response = ai_response.strip()
                
                # Assurer une réponse professionnelle
                if not ai_response or len(ai_response) < 5:
                    return "Merci pour votre message. Comment puis-je vous aider ?"
                
                return ai_response
                
            else:
                print(f"❌ Erreur API DeepSeek: {response.status_code}")
                return "Merci pour votre message. Notre service IA est temporairement indisponible, mais je peux toujours vous aider avec nos services de base."
                
    except Exception as e:
        print(f"❌ Exception IA: {e}")
        return "Merci pour votre message. Je rencontre une difficulté technique momentanée. Pouvez-vous reformuler votre demande ?"
