"""
Service WhatsApp managé pour NéoBot avec QR code intégré
"""
import asyncio
import json
import logging
from typing import Dict, Optional
import threading
from sqlalchemy.orm import Session

logger = logging.getLogger(__name__)

class WhatsAppManager:
    _instance = None
    _sock = None
    _is_connected = False
    _qr_code = None
    _connection_listeners = []
    
    def __new__(cls):
        if cls._instance is None:
            cls._instance = super(WhatsAppManager, cls).__new__(cls)
        return cls._instance
    
    def __init__(self):
        if not hasattr(self, '_initialized'):
            self._initialized = True
            self._loop = asyncio.new_event_loop()
            self._thread = None
    
    def start(self):
        """Démarrer le service WhatsApp dans un thread séparé"""
        if self._thread and self._thread.is_alive():
            return
            
        self._thread = threading.Thread(target=self._run_whatsapp, daemon=True)
        self._thread.start()
        logger.info("🚀 Service WhatsApp managé démarré")
    
    def _run_whatsapp(self):
        """Exécuter WhatsApp dans un thread asyncio"""
        asyncio.set_event_loop(self._loop)
        self._loop.run_until_complete(self._init_whatsapp())
    
    async def _init_whatsapp(self):
        """Initialiser la connexion WhatsApp"""
        try:
            # Import dynamique pour éviter les problèmes de dépendances
            from @whiskeysockets/baileys import makeWASocket, useMultiFileAuthState
            
            logger.info("📱 Initialisation de WhatsApp...")
            
            auth_state = await useMultiFileAuthState('whatsapp_auth')
            
            self._sock = makeWASocket({
                'auth': auth_state.state,
                'printQRInTerminal': False,  # On gère le QR nous-mêmes
                'logger': logging.getLogger('baileys')
            })
            
            # Événements
            self._sock.ev.on('creds.update', auth_state.saveCreds)
            self._sock.ev.on('connection.update', self._handle_connection_update)
            self._sock.ev.on('messages.upsert', self._handle_messages)
            
        except Exception as e:
            logger.error(f"❌ Erreur initialisation WhatsApp: {e}")
    
    def _handle_connection_update(self, update):
        """Gérer les mises à jour de connexion"""
        from qrcode import QRCode
        import io
        import base64
        
        if update.get('qr'):
            # Générer QR code pour le frontend
            qr = QRCode()
            qr.add_data(update['qr'])
            
            buffer = io.BytesIO()
            qr_img = qr.make_image()
            qr_img.save(buffer, format='PNG')
            
            self._qr_code = base64.b64encode(buffer.getvalue()).decode()
            self._is_connected = False
            logger.info("📱 QR Code généré pour le dashboard")
            
        elif update.get('connection') == 'open':
            self._qr_code = None
            self._is_connected = True
            logger.info("✅ WhatsApp connecté avec succès!")
            
        elif update.get('connection') == 'close':
            self._is_connected = False
            logger.info("🔌 WhatsApp déconnecté")
        
        # Notifier les listeners
        for listener in self._connection_listeners:
            try:
                listener(self.get_status())
            except:
                pass
    
    async def _handle_messages(self, messages_upsert):
        """Traiter les messages entrants"""
        try:
            from app.services.fallback_service import FallbackService
            from app.database import SessionLocal
            from app.models import Tenant, Conversation, Message
            
            message = messages_upsert['messages'][0]
            if not message.message or message.key.fromMe:
                return
            
            phone = message.key.remoteJid.replace('@s.whatsapp.net', '')
            message_text = self._extract_message_text(message.message)
            
            if not message_text:
                return
            
            logger.info(f"📩 Message de {phone}: {message_text}")
            
            # Traiter via le backend existant
            db = SessionLocal()
            try:
                fallback_service = FallbackService(db)
                tenant = db.query(Tenant).filter(Tenant.id == 1).first()
                
                if tenant:
                    intent, confidence = fallback_service.detect_intent(message_text, tenant.business_type)
                    use_fallback = fallback_service.should_use_fallback(message_text)
                    
                    if use_fallback:
                        reply = fallback_service.get_fallback_response(message_text, tenant.business_type, tenant.name)
                    else:
                        from app.main import generate_ai_response
                        reply = await generate_ai_response(tenant, message_text)
                    
                    # Envoyer la réponse
                    await self._sock.sendMessage(message.key.remoteJid, {'text': reply})
                    logger.info(f"📤 Réponse envoyée: {reply[:50]}...")
                    
            finally:
                db.close()
                
        except Exception as e:
            logger.error(f"❌ Erreur traitement message: {e}")
    
    def _extract_message_text(self, message):
        """Extraire le texte du message"""
        if message.conversation:
            return message.conversation
        if message.extendedTextMessage:
            return message.extendedTextMessage.text
        return ''
    
    def get_status(self):
        """Obtenir le statut actuel"""
        return {
            'connected': self._is_connected,
            'qr_code': self._qr_code,
            'status': 'connected' if self._is_connected else 'disconnected'
        }
    
    def add_connection_listener(self, listener):
        """Ajouter un listener pour les mises à jour de connexion"""
        self._connection_listeners.append(listener)
    
    def restart_connection(self):
        """Redémarrer la connexion WhatsApp"""
        if self._sock:
            self._sock.endConnection()
        self.start()

# Instance globale
whatsapp_manager = WhatsAppManager()
