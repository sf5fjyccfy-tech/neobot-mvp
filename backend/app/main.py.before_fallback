# Schemas
class TenantCreate(BaseModel):
    name: str
    email: str
    phone: str
    business_type: Optional[str] = "autre"

# Fonction IA
async def generate_ai_response(tenant: Tenant, message: str, history: list = None) -> str:
    simple = {
        r"^(salut|bonjour|bonsoir|hello)[\s!?]*$": f"Bonjour ! Bienvenue chez {tenant.name}. Comment puis-je vous aider ?",
        r"^(merci|thanks)[\s!?]*$": "Avec plaisir !",
        r"^(au revoir|bye)[\s!?]*$": f"Au revoir ! À bientôt."
    }
    
    msg_lower = message.lower().strip()
    for pattern, response in simple.items():
        if re.match(pattern, msg_lower, re.IGNORECASE):
            return response
    
    if len(message.split()) <= 2:
        return "Bonjour ! Pouvez-vous préciser votre demande ?"
    
    try:
        messages = build_chat_messages(tenant, message, history)
        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.post(
                AI_URL,
                json={"model": "deepseek-chat", "messages": messages, "temperature": 0.7, "max_tokens": 150},
                headers={"Authorization": f"Bearer {AI_API_KEY}"}
            )
            if response.status_code == 200:
                return response.json()["choices"][0]["message"]["content"]
    except:
        pass
    
    return f"Merci pour votre message. Notre équipe vous répond rapidement."

