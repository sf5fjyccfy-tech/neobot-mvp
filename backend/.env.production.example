# ==================== CONFIGURATION PRODUCTION ====================
# IMPORTANT: NE JAMAIS committer ce fichier avec les vraies clés !
# Utiliser GitHub Secrets ou un vault (Vault, AWS Secrets Manager, etc.)
# Voir SETUP_SECRETS.md pour plus de détails

# Base de données PostgreSQL (Production)
DATABASE_URL=**MASKED**

# Clé API DeepSeek (MASQUÉE EN PRODUCTION)
# ⚠️ SECRETS: Utiliser GitHub Secrets > DEEPSEEK_API_KEY_PROD
# Format: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Masquée comme: sk-****-****-****
DEEPSEEK_API_KEY=**MASKED**

# URL de base pour l'API
BASE_URL=https://api.neobot.prod

# URL du service WhatsApp (production)
WHATSAPP_SERVICE_URL=https://whatsapp-service.neobot.prod

# Clé de chiffrement (optionnel)
ENCRYPTION_KEY=**MASKED**
