# ========== PRODUCTION CONFIGURATION FOR NÉOBOT ==========
# This file is a TEMPLATE - actual secrets must come from environment variables!
# Use AWS Secrets Manager, Vault, or system environment variables

# ========== DATABASE CONFIGURATION ==========
# In production, get from AWS RDS or environment variable
DATABASE_URL=postgresql://neobot:${DB_PASSWORD}@db.example.com:5432/neobot_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# ========== IA API CONFIGURATION ==========
# Store in AWS Secrets Manager or Vault - NEVER in git!
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ========== BACKEND CONFIGURATION ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=production
BACKEND_DEBUG=false
BACKEND_RELOAD=false

# ========== WHATSAPP CONFIGURATION ==========
WHATSAPP_BACKEND_URL=https://api.votre-domaine.com
WHATSAPP_SERVICE_URL=http://whatsapp-service:3001
WHATSAPP_WEBHOOK_SECRET=${WHATSAPP_WEBHOOK_SECRET}

# ========== APPLICATION CONFIGURATION ==========
APP_NAME=NéoBot
APP_VERSION=1.0.0
DEBUG_MODE=false

# ========== JWT SECURITY ==========
# MUST be stored in vault/environment - random 32+ character string
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FILE=/var/log/neobot/app.log
