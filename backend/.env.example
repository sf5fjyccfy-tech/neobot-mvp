# ========== DATABASE CONFIGURATION ==========
# Format: postgresql://username:password@host:port/database
# IMPORTANT: NEVER commit real passwords to git
DATABASE_URL=postgresql://neobot:YOUR_DB_PASSWORD@localhost:5432/neobot_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ========== IA API CONFIGURATION ==========
# Get from: https://platform.deepseek.com/api_keys
# IMPORTANT: Keep your API key secret!
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ========== BACKEND CONFIGURATION ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
BACKEND_DEBUG=false
BACKEND_RELOAD=true

# ========== WHATSAPP CONFIGURATION ==========
WHATSAPP_BACKEND_URL=http://localhost:8000
WHATSAPP_SERVICE_URL=http://localhost:3001
WHATSAPP_WEBHOOK_SECRET=your_secret_webhook_key_here

# ========== BREVO (emails transactionnels) ==========
# Créer un compte sur https://app.brevo.com → Paramètres → Clés API
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=contact@neobot-ai.com
BREVO_SENDER_NAME=NeoBot
BREVO_REPLY_TO=contact@neobot-ai.com
# URL du frontend (utilisée dans les liens des emails)
FRONTEND_URL=https://app.votre-domaine.com

# ========== APPLICATION CONFIGURATION ==========
APP_NAME=NéoBot
APP_VERSION=1.0.0
DEBUG_MODE=false
# CRITIQUE : définir "production" en prod — active HSTS + rejet HMAC strict
APP_ENV=development   # valeurs: development | production
# Origines CORS autorisées en production (séparées par virgule)
ALLOWED_ORIGINS=https://app.neobot-ai.com,https://neobot-ai.com

# ========== INTERNAL API KEY ==========
# Clé partagée entre backend et whatsapp-service pour les appels internes
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=generate_with_secrets_token_hex_32

# ========== JWT SECURITY ==========
# IMPORTANT: Change to random string in production!
JWT_SECRET=change_this_to_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FILE=/home/tim/neobot-mvp/logs/app.log

# ========== NEOPAY — KORAPAY ==========
# Dashboard : https://dashboard.korapay.com → Developers → API Keys
KORAPAY_PUBLIC_KEY=pk_test_...
KORAPAY_SECRET_KEY=sk_test_...
KORAPAY_ENCRYPTION_KEY=...

# ========== NEOPAY — CAMPAY ==========
# Dashboard : https://campay.net → API Settings
CAMPAY_USERNAME=your-campay-username
CAMPAY_PASSWORD=your-campay-password
# CRITIQUE : ne jamais passer à true avant déploiement sur neobot.app
CAMPAY_PRODUCTION=false

# ========== NEOPAY — CONFIG ==========
# URL publique du backend pour les webhooks Korapay/CamPay (ngrok en dev)
BACKEND_URL=https://api.neobot.app
# Email qui reçoit les alertes internes (webhook mort, fallback provider, etc.)
NEOPAY_ALERT_EMAIL=neobot561@gmail.com

# ========== SENTRY AUTO-ANALYSE ==========
# Clé Anthropic (Claude Haiku) pour l'analyse automatique des erreurs Sentry
ANTHROPIC_API_KEY=sk-ant-...
# Secret Sentry : Settings → Integrations → Webhooks → "Signing Secret"
SENTRY_WEBHOOK_SECRET=

# ========== GITHUB ISSUES AUTO-CRÉATION ==========
# Personal Access Token avec scope 'repo'
GITHUB_TOKEN=ghp_...
GITHUB_REPO_BACKEND=sf5fjyccfy-tech/neobot-mvp
GITHUB_REPO_FRONTEND=
GITHUB_REPO_WHATSAPP=

# ========== ALERTES ADMIN ==========
# Numéro WhatsApp de l'admin pour les alertes critiques (format international)
ADMIN_WHATSAPP=+237XXXXXXXXX
