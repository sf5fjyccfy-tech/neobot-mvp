# Configuration de la base de données PostgreSQL
# Remplace host, user, password, et dbname par tes vraies valeurs
# Exemple local: postgresql://neobot:password@localhost:5432/neobot
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé API DeepSeek pour l'intégration IA
# Génère ta clé sur: https://platform.deepseek.com/api_keys
# IMPORTANT: Ne committe JAMAIS cette clé dans le repo !
# Utilise plutôt les secrets GitHub Actions ou un vault sécurisé
DEEPSEEK_API_KEY=sk-test

# Clé de chiffrement (optionnel)
ENCRYPTION_KEY=

# URL de base pour l'API
BASE_URL=http://localhost:8000

# URL du service WhatsApp (local ou distant)
WHATSAPP_SERVICE_URL=http://localhost:3001
